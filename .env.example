# --- Friend Group Auth example app ---
# Copy this file to `.env.local` and fill in the secrets, then `npm run dev`.
# The app runs on http://localhost:3330 (set in package.json) so the redirect
# URIs below match exactly.

# The auth server.
AUTH_BASE_URL=http://localhost:3000

# Your app's OAuth client id (the spec's CLIENT_ID).
FGC_CLIENT_ID=fgc_gX-ks_JrUNc

# SERVER-ONLY. The secret shown when you registered the app. Never exposed to
# the browser (no NEXT_PUBLIC_ prefix → not bundled for the client).
FGC_CLIENT_SECRET=PASTE_THE_SECRET_SHOWN_WHEN_YOU_REGISTERED

# Must match a registered redirect URI EXACTLY.
FGC_REDIRECT_URI=http://localhost:3330/callback

# The pay return URL. Must ALSO be a registered redirect URI.
FGC_PAY_REDIRECT_URI=http://localhost:3330/pay/callback

# SERVER-ONLY. Used to HMAC-sign our own session cookies. Generate a random
# value, e.g.  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
